{
    "name": "yet-another-todo-app",
    "version": "0.0.0",
    "author": "Krzysztof Pająk",
    "description": "Todo application",
    "main": "app.js",
    "scripts": {
        "ng": "ng",
        "start": "ng serve -o",
        "build": "ng build --base-href ./ && electron-builder",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "electron-start": "ng build --base-href ./ && electron ."
    },
    "build": {
        "appId": "com.chrisaraneo.yet-another-todo-app",
        "productName": "Yet Another Todo App",
        "win": {
            "target": [
                "portable"
            ]
        },
        "directories": {
            "app": ".",
            "output": "dist/yet-another-todo-app-electron/",
            "buildResources": "build-res"
        },
        "files": [
            "LICENSE",
            "app.js",
            "package.json",
            {
                "from": "dist/yet-another-todo-app-angular/",
                "to": "."
            }
        ]
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^12.2.16",
        "@angular/cdk": "^13.3.7",
        "@angular/common": "~12.2.0",
        "@angular/compiler": "~12.2.0",
        "@angular/core": "~12.2.0",
        "@angular/flex-layout": "^13.0.0-beta.38",
        "@angular/forms": "~12.2.0",
        "@angular/material": "^13.3.7",
        "@angular/platform-browser": "~12.2.0",
        "@angular/platform-browser-dynamic": "~12.2.0",
        "@angular/router": "~12.2.0",
        "@ngrx/store": "^13.2.0",
        "express": "^4.18.1",
        "ngx-electron": "^2.2.0",
        "rxjs": "~6.6.0",
        "tslib": "^2.3.0",
        "zone.js": "~0.11.4"
    },
    "devDependencies": {
        "@angular-builders/custom-webpack": "^12.1.1",
        "@angular-devkit/build-angular": "~12.2.0",
        "@angular/cli": "~12.2.0",
        "@angular/compiler-cli": "~12.2.0",
        "@types/jasmine": "~3.8.0",
        "@types/node": "16.6.1",
        "electron": "13.1.9",
        "electron-builder": "^23.0.3",
        "eslint-plugin-prettier": "^4.0.0",
        "jasmine-core": "~3.8.0",
        "karma": "~6.3.0",
        "karma-chrome-launcher": "~3.1.0",
        "karma-coverage": "~2.0.3",
        "karma-jasmine": "~4.0.0",
        "karma-jasmine-html-reporter": "~1.7.0",
        "node-polyfill-webpack-plugin": "^1.1.4",
        "typescript": "~4.3.5"
    }
}